/**
 * prisma/schema.prisma:
 */
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum EstadoMatricula {
  ACTIVA
  INACTIVA
  ANULADA
}

model Carrera {
  IdCarrera     Int      @id @default(autoincrement())
  NombreCarrera String   @unique
  Activo        Boolean  @default(true)
  FechaCreacion DateTime @default(now())

  Materias   Materia[]
  Matriculas Matricula[]
}

model Materia {
  IdMateria     Int           @id @default(autoincrement())
  NombreMateria String
  Activo        Boolean       @default(true)
  FechaCreacion DateTime      @default(now())
  CarreraFK     Int
  Carrera       Carrera       @relation(fields: [CarreraFK], references: [IdCarrera])
  Laboratorios  Laboratorio[]

  @@unique([NombreMateria, CarreraFK])
}

model Ciclo {
  IdCiclo      Int           @id @default(autoincrement())
  NombreCiclo  String        @unique
  Activo       Boolean       @default(true)
  FechaInicio  DateTime?
  FechaFin     DateTime?
  Matriculas   Matricula[]
  Laboratorios Laboratorio[]
}

model Estudiante {
  IdEstudiante       Int         @id @default(autoincrement())
  NombreEstudiante   String
  ApellidoEstudiante String
  CedulaEstudiante   String      @unique
  CorreoEstudiante   String      @unique
  Activo             Boolean     @default(true)
  Matriculas         Matricula[]
}

model Matricula {
  IdMatricula     Int             @id @default(autoincrement())
  EstadoMatricula EstadoMatricula @default(ACTIVA)
  LugarAsignado   String
  FechaMatricula  DateTime        @default(now())
  EstudianteFK    Int
  CarreraFK       Int
  CicloFK         Int
  Estudiante      Estudiante      @relation(fields: [EstudianteFK], references: [IdEstudiante])
  Carrera         Carrera         @relation(fields: [CarreraFK], references: [IdCarrera])
  Ciclo           Ciclo           @relation(fields: [CicloFK], references: [IdCiclo])
  Laboratorios    Laboratorio[]

  @@unique([EstudianteFK, CarreraFK, CicloFK])
}

model Laboratorio {
  IdLaboratorio     Int       @id @default(autoincrement())
  NombreLaboratorio String
  Activo            Boolean   @default(true)
  CicloFK           Int
  MatriculaFK       Int
  MateriaFK         Int
  Ciclo             Ciclo     @relation(fields: [CicloFK], references: [IdCiclo])
  Matricula         Matricula @relation(fields: [MatriculaFK], references: [IdMatricula])
  Materia           Materia   @relation(fields: [MateriaFK], references: [IdMateria])

  @@unique([NombreLaboratorio, CicloFK, MatriculaFK, MateriaFK])
}
